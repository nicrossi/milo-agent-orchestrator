ENV=local
GOOGLE_API_KEY="GOOGLE_API_KEY"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/milo
DB_POOL_SIZE="10"
DB_MAX_OVERFLOW="10"
FIREBASE_SERVICE_ACCOUNT_PATH="serviceaccountjsonpath"
AUTH_REQUIRED=true
VERTEX_PROJECT="your-gcp-project-id"
VERTEX_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
AUTO_EVALUATE_ON_CHAT_CLOSE=true

# Email (Resend) — emails are silently skipped if RESEND_API_KEY is empty.
RESEND_API_KEY=""
EMAIL_FROM="Milo <onboarding@resend.dev>"
FRONTEND_BASE_URL="http://localhost:3000"
